{
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://mail.google.com/*",
    "http://localhost:8080/*"
  ],
  "name": "Smart Email Writer Assistant",
  "version": "1.0.0",
  "description": "AI-powered email writing assistant that helps you compose professional and effective emails with ease.",
  "action":{
    "default_title": "Smart Email Writer Assistant",
    "default_icon":"OIP.jpg"
  },
  "content_scripts": [
    {
        "js":[
            "content.js"
        ],
      "matches": ["*://mail.google.com/*"],
      "css": [
        "content.css"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["*://mail.google.com/*"]
    }
  ]
}